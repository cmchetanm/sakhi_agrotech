# Nginx configuration for sakhiagrotech.com
# Next.js serves the public site; Rails handles API, admin, and Active Storage.

upstream nextjs {
  server 127.0.0.1:3000;
}

upstream puma {
  server unix:/home/ubuntu/sakhiagrotech/shared/tmp/sockets/puma.sock;
}

server {
  listen 80;
  server_name sakhiagrotech.com www.sakhiagrotech.com;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name sakhiagrotech.com www.sakhiagrotech.com;

  ssl_certificate /etc/letsencrypt/live/sakhiagrotech.com-0001/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/sakhiagrotech.com-0001/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  client_max_body_size 20M;

  # Rails: API, admin, Active Storage, and Sprockets assets (ActiveAdmin CSS/JS)
  location ~ ^/(api|rails|admin|assets) {
    proxy_pass http://puma;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Next.js: public site
  location / {
    proxy_pass http://nextjs;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
